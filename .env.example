# ============================================================
# HORIZON URL SHORTENER — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in all values.
# Never commit the actual .env file to version control.
# ============================================================

# Spring profile: use 'prod' for cloud deployment, 'dev' for local development
SPRING_PROFILES_ACTIVE=prod

# ============================================================
# DATABASE (Required for prod profile)
# ============================================================
# MySQL/PlanetScale JDBC URL
DB_URL=jdbc:mysql://your-db-host:3306/url_shortener?useSSL=true&requireSSL=true&serverTimezone=UTC
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ============================================================
# JWT AUTHENTICATION (Required for prod profile)
# ============================================================
# Generate a secure random 256-bit (32+ byte) secret:
# openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=2592000000

# ============================================================
# REDIS (Required for prod profile)
# ============================================================
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
# Set to true if your Redis provider uses TLS/SSL (e.g. Railway, Upstash with SSL)
REDIS_SSL=false

# ============================================================
# FRONTEND / CORS (Required for prod profile)
# ============================================================
# The base URL where your frontend is hosted (used for CORS)
FRONTEND_URL=https://your-frontend-domain.com

# Optional: comma-separated list of additional allowed CORS origins
# CORS_ALLOWED_ORIGINS=https://staging.example.com,https://app.example.com

# ============================================================
# SERVER (Optional)
# ============================================================
# Port the backend listens on (default: 8080)
# PORT=8080
